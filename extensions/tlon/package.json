{
  "name": "@remoteclaw/tlon",
  "version": "0.1.0",
  "description": "RemoteClaw Tlon/Urbit channel plugin",
  "type": "module",
  "dependencies": {
    "@tloncorp/api": "github:tloncorp/api-beta#main",
    "@tloncorp/tlon-skill": "0.2.2",
    "@urbit/aura": "^3.0.0",
    "zod": "^4.3.6"
  },
  "remoteclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "tlon",
      "label": "Tlon",
      "selectionLabel": "Tlon (Urbit)",
      "docsPath": "/channels/tlon",
      "docsLabel": "tlon",
      "blurb": "decentralized messaging on Urbit; install the plugin to enable.",
      "order": 90,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@remoteclaw/tlon",
      "localPath": "extensions/tlon",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.3.14"
    }
  }
}
