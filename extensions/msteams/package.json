{
  "name": "@remoteclaw/msteams",
  "version": "2026.3.14",
  "description": "RemoteClaw Microsoft Teams channel plugin",
  "type": "module",
  "dependencies": {
    "@microsoft/agents-hosting": "^1.3.1",
    "express": "^5.2.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "remoteclaw": "workspace:*"
  },
  "peerDependencies": {
    "remoteclaw": ">=2026.3.14"
  },
  "peerDependenciesMeta": {
    "remoteclaw": {
      "optional": true
    }
  },
  "remoteclaw": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "msteams",
      "label": "Microsoft Teams",
      "selectionLabel": "Microsoft Teams (Bot Framework)",
      "docsPath": "/channels/msteams",
      "docsLabel": "msteams",
      "blurb": "Bot Framework; enterprise support.",
      "aliases": [
        "teams"
      ],
      "order": 60
    },
    "install": {
      "npmSpec": "@remoteclaw/msteams",
      "localPath": "extensions/msteams",
      "defaultChoice": "npm"
    },
    "release": {
      "publishToNpm": true
    }
  }
}
