{
  "name": "@remoteclaw/irc",
  "version": "0.1.0",
  "description": "RemoteClaw IRC channel plugin",
  "type": "module",
  "dependencies": {
    "zod": "^4.3.6"
  },
  "remoteclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "minHostVersion": ">=2026.3.14"
    },
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "irc",
      "label": "IRC",
      "selectionLabel": "IRC (Server + Nick)",
      "detailLabel": "IRC",
      "docsPath": "/channels/irc",
      "docsLabel": "irc",
      "blurb": "classic IRC networks with DM/channel routing and pairing controls.",
      "systemImage": "network"
    }
  }
}
